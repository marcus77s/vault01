    "includeFrontmatter": true,
    "frontmatterTemplate": "---\n title: \"{{title}}\"\n date: \"{{date}}\"\n tags: [{{tags}}]\n source: \"{{source}}\"\n link: \"{{link}}\"\n author: \"{{author}}\"\n feedTitle: \"{{feedTitle}}\"\n summary: \"{{summary}}\"\n guid: \"{{guid}}\"\n---",
